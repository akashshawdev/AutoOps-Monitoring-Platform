# GitHub Personal Access Token (needs repo + actions:read scope)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Repo to monitor e.g. akash-k-shaw/autoops
GITHUB_REPO=your-username/your-repo

# URL of your deployed frontend (for CORS / health check)
FRONTEND_URL=https://your-app.vercel.app

# URL of this API itself (used in health check) — Railway auto-assigns this
SELF_URL=https://your-service.up.railway.app
